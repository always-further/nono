{
  "extends": "default",
  "meta": {
    "name": "eti-aws-credentials-no-curl",
    "version": "1.0.0",
    "description": "Allow Fedora's Python-packaged aws CLI to read AWS credentials while denying curl",
    "author": "local"
  },
  "workdir": {
    "access": "none"
  },
  "command_policies": {
    "session_can_use": [
      "aws"
    ],
    "commands": {
      "aws": {
        "executable": "/usr/sbin/aws",
        "sandbox": {
          "fs_read": [
            ".",
            "$HOME/.aws/cli",
            "/usr/lib/python3.14",
            "/usr/lib64/python3.14"
          ],
          "fs_read_file": [
            "$HOME/.aws/credentials",
            "$HOME/.aws/config",
            "/etc/pki/tls/certs/ca-bundle.crt",
            "/etc/ssl/certs/ca-certificates.crt",
            "/proc/sys/crypto/fips_enabled",
            "/proc/sys/vm/overcommit_memory",
            "/usr/lib64/libcrypto.so.3",
            "/usr/lib64/libexpat.so.1",
            "/usr/lib64/libffi.so.8",
            "/usr/lib64/libsqlite3.so.0",
            "/usr/lib64/libssl.so.3",
            "/usr/lib64/libz.so.1",
            "/usr/pyvenv.cfg"
          ],
          "fs_write": [
            "$HOME/.aws/cli"
          ],
          "network": {
            "tcp_connect_ports": [
              443
            ]
          },
          "environment": {
            "allow_vars": [
              "PATH",
              "HOME",
              "USER",
              "LOGNAME",
              "TERM",
              "LANG",
              "LC_*",
              "AWS_PROFILE",
              "AWS_REGION",
              "AWS_DEFAULT_REGION",
              "AWS_EC2_METADATA_DISABLED"
            ],
            "set_vars": {
              "AWS_PAGER": ""
            }
          }
        }
      },
      "curl": {
        "executable": "/usr/bin/curl",
        "from": {
          "session": "deny"
        }
      }
    }
  }
}
